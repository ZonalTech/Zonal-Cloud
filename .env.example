# Zonal Cloud environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# Postgres
# ------------------------------------------------------------------
# Hostname as seen from other containers on zonal_net.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=zonal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=zonal

# Full DSN used by the API (Prisma DATABASE_URL).
# When running api via npm (dev), use localhost:5432 instead of postgres:5432.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
# Hostname as seen from other containers on zonal_net.
REDIS_HOST=redis
REDIS_PORT=6379
# When running api via npm (dev), use localhost:6379 instead of redis:6379.
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ------------------------------------------------------------------
# API (set by backend agent, referenced here for documentation)
# ------------------------------------------------------------------
# API listens on this port (SPEC section 5).
API_PORT=4000

# JWT signing secret -- must be a long random string in production.
JWT_SECRET=change-this-to-a-random-string

# ------------------------------------------------------------------
# Traefik / proxy
# ------------------------------------------------------------------
# LOCAL: no TLS, routes *.localhost over HTTP.
# VPS (future): set your real domain here and update traefik.yml ACME config.
# DOMAIN=yourdomain.com

# ------------------------------------------------------------------
# Managed DNS hosting (PowerDNS)
# ------------------------------------------------------------------
# Shared API key between the pdns container and the API. CHANGE in production.
PDNS_API_KEY=changeme-pdns-api-key
# Dedicated database (inside the shared Postgres) for PowerDNS record data.
PDNS_DB=pdns
# How the API reaches the PowerDNS HTTP API (in-network; never published to host).
PDNS_API_URL=http://pdns:8081
# PowerDNS server id in its API (almost always "localhost").
PDNS_SERVER_ID=localhost
# Base domain the platform's nameservers live under. Customers delegate to
# ns1.<DNS_BASE_DOMAIN> / ns2.<DNS_BASE_DOMAIN>.
DNS_BASE_DOMAIN=oponde.top
# Optional explicit override of the nameserver hostnames (comma-separated).
# Defaults to ns1.<DNS_BASE_DOMAIN>,ns2.<DNS_BASE_DOMAIN> when unset.
# DNS_NAMESERVERS=ns1.oponde.top,ns2.oponde.top
