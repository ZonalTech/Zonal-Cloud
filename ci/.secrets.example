# Copy this file to .secrets in the repository root (NOT inside ci/).
# Never commit .secrets — it is listed in .gitignore.
#
# Usage:
#   cp ci/.secrets.example .secrets
#   # edit .secrets with your real values
#   act push --secret-file .secrets --var ZONAL_APP_ID=<id> --var ZONAL_API_BASE=http://host.docker.internal:4000 --actrc ci/.actrc

# Deploy token created via POST /v1/apps/:id/tokens (plaintext, returned once only).
ZONAL_TOKEN=replace_with_your_deploy_token

# App ID (also set as a repo variable; duplicated here for convenience in act CLI flags).
ZONAL_APP_ID=replace_with_your_app_id

# API base URL for local act runs.
# Use http://host.docker.internal:4000 (recommended, see ci/README.md section 6).
# Use http://localhost:4000 only when running act with --network host.
ZONAL_API_BASE=http://host.docker.internal:4000
