# ------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/

# ------------------------------------------------------------------
# Build output
# ------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# ------------------------------------------------------------------
# Environment files and secrets
# ------------------------------------------------------------------
# Never commit real environment files; .env.example is the committed template.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Local act secrets file (GitHub Actions local testing) — must never be committed.
.secrets

# zonalctl generated artifacts.
# traefik.prod.yml is rendered from traefik.prod.yml.template (contains the
# operator's ACME email); the template is committed, the rendered file is not.
services/proxy/traefik.prod.yml
# Database backups produced by `zonalctl backup`.
backups/
**/.secrets
!**/.secrets.example

# ------------------------------------------------------------------
# Prisma
# ------------------------------------------------------------------
# Generated Prisma client (regenerated via `prisma generate`).
**/node_modules/.prisma/
apps/api/prisma/*.db
apps/api/prisma/*.db-journal

# ------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------------
# Vite / frontend caches
# ------------------------------------------------------------------
.vite/
**/.vite/
*.local

# ------------------------------------------------------------------
# Docker / runtime data
# ------------------------------------------------------------------
# Persisted volumes if ever bind-mounted into the repo.
data/
postgres-data/
redis-data/
letsencrypt/
acme.json

# ------------------------------------------------------------------
# Editor / OS
# ------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ------------------------------------------------------------------
# Test / coverage
# ------------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------------
# Temp / scratch
# ------------------------------------------------------------------
tmp/
temp/
*.tmp
